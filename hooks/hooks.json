{
  "description": "Validates task file YAML frontmatter on write/edit",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/validate_task.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
